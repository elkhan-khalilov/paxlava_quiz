# ==== Paxlava Quiz — mühit dəyişənləri ====
# Bu faylı .env adı ilə kopyalayın və dəyərləri doldurun:
#   cp .env.example .env

# Flask sessiya imzalama açarı — UZUN və TƏSADÜFİ olmalıdır.
# Yaratmaq üçün:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Giriş parolları (mütləq dəyişin!)
ADMIN_PASSWORD=
USER_PASSWORD=

# HTTPS arxasında işlədikdə cookie-lər yalnız https ilə göndərilsin
SESSION_COOKIE_SECURE=true

# nginx-proxy konteynerinin qoşulu olduğu Docker şəbəkəsinin adı.
# Tapmaq üçün:
#   docker inspect nginx-proxy -f '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
PROXY_NETWORK=nginx-proxy
