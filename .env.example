# Copy to .env and adjust. docker-compose reads these automatically.

# Flask session signing key — set to a long random value in production, e.g.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# Login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123
